# Firebase web app config — copy this file to `.env` and fill in your own values.
# Find these in Firebase Console → Project settings → Your apps → SDK setup & config.
# The `.env` file is gitignored; never commit real keys.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional: pre-created demo account used by the one-click "Demo login" button.
# Create this user in Firebase Auth (email/password) and mirror the values here.
VITE_DEMO_EMAIL=demo@example.com
VITE_DEMO_PASSWORD=
