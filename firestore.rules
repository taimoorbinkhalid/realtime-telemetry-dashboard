rules_version = '2';

// Public demo rules: any signed-in user may READ telemetry, but nobody may
// write from the client. All writes come from the trusted seeder (Admin SDK,
// which bypasses these rules). This keeps the live demo tamper-proof.
service cloud.firestore {
  match /databases/{database}/documents {

    match /devices/{deviceId} {
      allow read: if request.auth != null;
      allow write: if false;

      match /readings/{readingId} {
        allow read: if request.auth != null;
        allow write: if false;
      }
    }

    // Alerts are written only by Cloud Functions (Admin SDK bypasses rules);
    // any signed-in user may read them.
    match /alerts/{alertId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Per-user data (favorites, acknowledgements, settings): each user may only
    // read and write documents under their own uid. This is the only place
    // clients are allowed to write.
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Deny everything else by default (including the internal alertState pointers).
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
