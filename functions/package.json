{
  "name": "functions",
  "private": true,
  "description": "Cloud Functions: scheduled telemetry generator + threshold alert trigger.",
  "engines": {
    "node": "22"
  },
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "lint": "eslint .",
    "test": "vitest",
    "test:run": "vitest run",
    "serve": "npm run build && firebase emulators:start --only functions,firestore"
  },
  "dependencies": {
    "firebase-admin": "^13.0.0",
    "firebase-functions": "^6.0.0"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "typescript": "~6.0.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.0.0"
  },
  "allowScripts": {
    "@firebase/util@1.15.1": true,
    "protobufjs@7.6.5": true
  }
}
